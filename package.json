{
	"name": "kims-obsidian-plugin",
	"version": "1.0.0",
	"private": true,
	"packageManager": "pnpm@10.28.2",
	"scripts": {
		"dev": "pnpm dev:obsidian-to-anki",
		"dev:obsidian-to-anki": "pnpm --filter obsidian-kims-obsidian-to-anki-plugin dev",
		"dev:plantuml": "pnpm --filter obsidian-kims-plantuml-plugin dev",
		"build": "pnpm -r --stream build",
		"test": "pnpm -r --if-present test",
		"lint": "pnpm -r --stream lint"
	},
	"devDependencies": {
		"eslint": "^9.39.1"
	}
}
